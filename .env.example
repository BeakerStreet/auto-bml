# ── Google Ads ────────────────────────────────────────────────────────────────
# Customer ID: top-right corner of your Google Ads account (digits only, no dashes)
GOOGLE_ADS_CUSTOMER_ID=

# Developer token: Google Ads → Tools → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 credentials: console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Desktop app type)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# Leave blank — auto-bml onboard will fill this in via browser OAuth flow
GOOGLE_ADS_REFRESH_TOKEN=

# ── Anthropic ─────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ── Deploy ────────────────────────────────────────────────────────────────────
# vercel or netlify
DEPLOY_PROVIDER=vercel

# Vercel: Project Settings → Git → Deploy Hooks
# Netlify: Site Settings → Build & Deploy → Build Hooks
DEPLOY_WEBHOOK_URL=

# Live URL of your landing page (e.g. https://your-project.vercel.app)
DEPLOY_SITE_URL=

# Vercel only — skip if using Netlify
# Personal access token: vercel.com → Settings → Tokens
VERCEL_API_TOKEN=
# Project ID: Vercel project → Settings → General → Project ID
VERCEL_PROJECT_ID=

# ── GitHub ────────────────────────────────────────────────────────────────────
# github.com → Settings → Developer settings → Personal access tokens
# Required scopes: repo, secrets
GITHUB_TOKEN=
